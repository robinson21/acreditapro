# =============================================================================
# AcreditaPro - Variables de Entorno
# Copia este archivo a .env y completa los valores correspondientes
# =============================================================================
# cp .env.example .env

# ---------------------------------------------------------------------------
# Generales
# ---------------------------------------------------------------------------
NODE_ENV=development
APP_NAME=AcreditaPro
APP_VERSION=1.0.0

# ---------------------------------------------------------------------------
# Backend
# ---------------------------------------------------------------------------
BACKEND_PORT=3001
BACKEND_HOST=0.0.0.0

# ---------------------------------------------------------------------------
# Base de datos PostgreSQL
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql://acreditapro:acreditapro_secret@localhost:5432/acreditapro
POSTGRES_USER=acreditapro
POSTGRES_PASSWORD=acreditapro_secret
POSTGRES_DB=acreditapro
POSTGRES_PORT=5432

# ---------------------------------------------------------------------------
# JWT (Autenticación)
# ---------------------------------------------------------------------------
JWT_SECRET=change_me_to_a_secure_random_string_in_production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ---------------------------------------------------------------------------
# MinIO (Almacenamiento de documentos)
# ---------------------------------------------------------------------------
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=acreditapro-docs
MINIO_USE_SSL=false
MINIO_REGION=us-east-1

# ---------------------------------------------------------------------------
# Frontend
# ---------------------------------------------------------------------------
VITE_API_URL=http://localhost:3001/api
VITE_APP_URL=http://localhost:5173
VITE_APP_NAME=AcreditaPro
VITE_UPLOAD_MAX_SIZE=10485760

# ---------------------------------------------------------------------------
# CORS (orígenes permitidos)
# ---------------------------------------------------------------------------
CORS_ORIGIN=http://localhost:5173,http://localhost:80,http://localhost:3001

# ---------------------------------------------------------------------------
# Rate Limiting
# ---------------------------------------------------------------------------
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ---------------------------------------------------------------------------
# Archivos subidos
# ---------------------------------------------------------------------------
UPLOAD_DIR=./uploads
UPLOAD_MAX_FILE_SIZE=10485760
UPLOAD_ALLOWED_MIME_TYPES=application/pdf,image/jpeg,image/png,image/webp,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
LOG_LEVEL=debug
LOG_FORMAT=dev

# ---------------------------------------------------------------------------
# Docker (solo relevante en contenedores)
# ---------------------------------------------------------------------------
DOCKER_NETWORK=acreditapro-net
