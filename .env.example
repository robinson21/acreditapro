# =============================================================================
# AcreditaPro - Variables de Entorno
# =============================================================================
# Copia este archivo a .env y ajusta los valores según tu entorno
# cp .env.example .env
#
# Para PRODUCCIÓN (Render): usa PostgreSQL
#   DATABASE_URL=postgresql://user:pass@host:5432/acreditapro
#
# Para DESARROLLO LOCAL (SQLite):
#   DATABASE_URL=file:./dev.db
#   (y copia prisma/schema.sqlite.prisma a prisma/schema.prisma)
# =============================================================================

# ---------------------------------------------------------------------------
# Generales
# ---------------------------------------------------------------------------
NODE_ENV=development
APP_NAME=AcreditaPro
APP_VERSION=1.0.0

# ---------------------------------------------------------------------------
# Backend
# ---------------------------------------------------------------------------
BACKEND_PORT=3001
BACKEND_HOST=0.0.0.0

# ---------------------------------------------------------------------------
# Base de datos (cambiar según entorno)
# ---------------------------------------------------------------------------
DATABASE_URL=file:./dev.db

# Para PostgreSQL local:
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/acreditapro

# ---------------------------------------------------------------------------
# JWT
# ---------------------------------------------------------------------------
JWT_SECRET=acreditapro-secret-key-dev
JWT_REFRESH_SECRET=acreditapro-refresh-secret-dev
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ---------------------------------------------------------------------------
# CORS
# ---------------------------------------------------------------------------
CORS_ORIGIN=http://localhost:5173

# ---------------------------------------------------------------------------
# Archivos
# ---------------------------------------------------------------------------
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=52428800

# ---------------------------------------------------------------------------
# IA (opcional)
# ---------------------------------------------------------------------------
AI_PROVIDER=openai
AI_API_KEY=
AI_MODEL=gpt-4o-mini
AI_API_URL=https://api.openai.com/v1

# ---------------------------------------------------------------------------
# Frontend (para build local de producción)
# ---------------------------------------------------------------------------
# VITE_API_URL=https://acreditapro-backend.onrender.com
# VITE_BASE_URL=/
